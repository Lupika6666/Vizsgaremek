    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jest": "^30.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
